# ============================================================
# 飞书 Claude Code 机器人 - 环境变量模板
# 复制为 .env 并填入真实值;在 Railway 里则填到 Variables 面板
# ============================================================

# ---------- Moonshot Kimi(后端模型) ----------
# 在 https://platform.moonshot.ai 注册后获取 API key
ANTHROPIC_AUTH_TOKEN=your_moonshot_api_key_here
ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic
ANTHROPIC_DEFAULT_OPUS_MODEL=kimi-k2.5
ANTHROPIC_DEFAULT_SONNET_MODEL=kimi-k2.5
ANTHROPIC_DEFAULT_HAIKU_MODEL=kimi-k2.5
# 视觉模型走 OpenAI 兼容端点(变量名保留 GLM_VISION_* 为历史原因)
GLM_VISION_MODEL=kimi-k2.5
GLM_VISION_BASE_URL=https://api.moonshot.ai/v1/chat/completions
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# ---------- 飞书企业自建应用 ----------
# 在飞书开放平台 https://open.feishu.cn 创建企业自建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 事件订阅的 Encrypt Key(在"事件与回调 → 加密策略"配置)
# 留空则不启用加密;启用后必填
FEISHU_ENCRYPT_KEY=

# 事件订阅的 Verification Token(在"事件与回调 → 加密策略"配置)
FEISHU_VERIFICATION_TOKEN=

# ---------- 访问控制 ----------
# 管理员 open_id(逗号分隔)。审批通知会主动发给这些管理员。
FEISHU_ADMIN_OPEN_IDS=ou_admin_open_id_here

# 历史兼容:启动时会把这些 open_id 预置为已开通用户(逗号分隔)
# 新增用户建议走 /apply + /approve,无需再修改这里
FEISHU_ALLOWED_OPEN_IDS=ou_seeded_user_open_id_here

# ---------- 数据持久化 ----------
# Railway 上必须挂载 Volume 到这个路径,否则容器重启数据全丢
DATA_DIR=/data

# ---------- 运行参数 ----------
# 单次 agent 任务最大时长(秒)
AGENT_MAX_DURATION_SECONDS=1800

# 定时任务每天最多触发次数(防失控)
SCHEDULE_DAILY_TRIGGER_LIMIT=50

# 日志级别
LOG_LEVEL=INFO
